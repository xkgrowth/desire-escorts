		<div class="elementor-element elementor-element-27a8636 e-con-full e-flex e-con e-child" data-id="27a8636" data-element_type="container" data-e-type="container" data-settings="{&quot;background_background&quot;:&quot;classic&quot;}">
				<div class="elementor-element elementor-element-2fe8198 elementor-widget elementor-widget-heading" data-id="2fe8198" data-element_type="widget" data-e-type="widget" data-widget_type="heading.default">
				<div class="elementor-widget-container">
